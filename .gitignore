# Node.js dependencies
/node_modules/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (if you use bower)
/bower_components/

# dotenv environment variables file
.env
.env.local
.env.*.local

# next.js build output (if you use next.js for API or frontend)
.next

# Dist folder (if you transpile TS or Babel)
/dist
/build

# Optional npm cache directory
.npm

# IDE files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# MacOS files
.DS_Store

# Yarn Integrity file
.yarn-integrity

# Optional eslint cache
.eslintcache
